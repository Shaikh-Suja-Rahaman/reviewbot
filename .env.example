# Copy to .env and fill in. NEVER commit the real .env.

# Anthropic API key — https://platform.claude.com
ANTHROPIC_API_KEY=sk-ant-...

# GitHub personal access token with repo scope (classic) or
# fine-grained with Contents:Read + Pull requests:Read/Write
GITHUB_TOKEN=ghp_...

# Shared secret configured on the GitHub webhook (Settings > Webhooks)
GITHUB_WEBHOOK_SECRET=change-me

# Optional overrides
# COPILOT_MODEL=claude-opus-4-8
# COPILOT_DB_PATH=copilot.db
